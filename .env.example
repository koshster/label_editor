SHIP_FROM_CITY=Irvine
SHIP_FROM_STATE=CA
SHIP_FROM_ZIP=92606
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=3102008051
SHIP_FROM_EMAIL=hello@priyum.com

# Parcel defaults
DEFAULT_BOX=12x9x6
PACKAGING_LBS=20
LABEL_DIR=labels
