# Shopify custom app token (Settings -> Apps -> Develop apps, scope: read_orders)
SHOPIFY_STORE=priyum-products.myshopify.com
SHOPIFY_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Ship-from address
SHIP_FROM_NAME=Priyum Products LLC
SHIP_FROM_COMPANY=Priyum Products LLC
SHIP_FROM_STREET1=123 Main St
SHIP_FROM_STREET2=
SHIP_FROM_CITY=Anytown
SHIP_FROM_STATE=CA
SHIP_FROM_ZIP=92688
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=5551234567
SHIP_FROM_EMAIL=orders@priyumproducts.com

# Parcel defaults
DEFAULT_BOX=12x9x6
PACKAGING_LBS=0.5
LABEL_DIR=labels
